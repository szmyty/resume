\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{resume}[2026/01/01 Resume Style]

% ============================================================
% Encoding and Typography
% ============================================================

\RequirePackage[utf8]{inputenc}
\RequirePackage[T1]{fontenc}
\RequirePackage{cmap}

\RequirePackage[english]{babel}

\RequirePackage{lmodern}
\RequirePackage{microtype}

% ============================================================
% Page Layout
% ============================================================

\RequirePackage[
  top=0.5in,
  bottom=0.5in,
  left=0.75in,
  right=0.75in,
  includeheadfoot
]{geometry}

\RequirePackage{parskip}

% ============================================================
% Colors
% ============================================================

\RequirePackage[dvipsnames]{xcolor}

\definecolor{resumeblue}{HTML}{1D4ED8}
\definecolor{resumegray}{HTML}{374151}
\definecolor{resumelightgray}{HTML}{9CA3AF}
\definecolor{resumeborder}{HTML}{E5E7EB}
\definecolor{resumeaccent}{HTML}{2563EB}

% ============================================================
% Hyperlinks and PDF Metadata
% ============================================================

\RequirePackage[
  colorlinks=true,
  linkcolor=resumeblue,
  urlcolor=resumeblue,
  citecolor=resumeblue,
  pdfborder={0 0 0},
  bookmarks=true,
  bookmarksopen=true
]{hyperref}

% ============================================================
% Lists and Spacing
% ============================================================

\RequirePackage{enumitem}

\setlist[itemize]{
  leftmargin=1.5em,
  topsep=2pt,
  itemsep=1pt,
  parsep=0pt
}

% ============================================================
% Section Formatting
% ============================================================

\RequirePackage{titlesec}

\titleformat{\section}
  {\large\bfseries\color{resumegray}}
  {}
  {0em}
  {}
  [\vspace{-0.5em}\color{resumeborder}\hrule\vspace{0.4em}]

\titlespacing{\section}{0pt}{0.8em}{0.3em}

% ============================================================
% Tables and Columns
% ============================================================

\RequirePackage{tabularx}
\RequirePackage{array}
\RequirePackage{multicol}

% ============================================================
% Header/Footer
% ============================================================

\RequirePackage{fancyhdr}

\fancyhf{}
\renewcommand{\headrulewidth}{0pt}

\fancyfoot[C]{\small\color{resumelightgray}\thepage}

% ============================================================
% Utility Commands
% ============================================================

\newcommand{\resumeentry}[4]{%
  \textbf{#1} \hfill \textit{#3} \\
  \textit{#2} \hfill \small\color{resumelightgray}#4
  \normalcolor
}

\newcommand{\resumeskillgroup}[2]{%
  \noindent\textbf{#1:} #2\par
}
