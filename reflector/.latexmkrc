#!/usr/bin/env perl

use strict;
use warnings;

use File::Path qw(make_path);

###############################################################################
# cache directories
###############################################################################

$out_dir = ".cache/out";

$aux_dir = ".cache/aux";

$emulate_aux = 1;

make_path($out_dir);

make_path($aux_dir);

###############################################################################
# environment
###############################################################################

$ENV{"TEXINPUTS"} =
    "./config//:"
    . "./styles//:"
    . "./macros//:"
    . "./sections//:"
    . "./figures//:"
    . "./diagrams//:";

$ENV{"TEXMFOUTPUT"} = $aux_dir;

###############################################################################
# build mode
###############################################################################

$pdf_mode = 1;

###############################################################################
# bibliography
###############################################################################

$biber =
    "biber "
    . "--input-directory=.cache/aux "
    . "--output-directory=.cache/aux "
    . "%B";

###############################################################################
# build behavior
###############################################################################

$silent = 1;

$max_repeat = 10;

$preview_mode = 0;

$do_cd = 1;

$force_mode = 1;
