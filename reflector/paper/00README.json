{
    "$schema": "https://arxiv.org/schemas/00readme/v1",
    "manifest_version": 1,

    "publication": {
        "title": "reflector: reflective synchronization systems for recursive AI-assisted software engineering",
        "status": "draft",
        "repository": "https://github.com/egohygiene/reflector",
        "pages_url": "https://egohygiene.github.io/reflector/"
    },

    "process": {
        "compiler": "pdflatex",
        "bibliography": "biber",
        "deterministic": true,
        "texlive": "2025",
        "max_repeat": 10
    },

    "sources": [
        {
            "path": "paper.tex",
            "usage": "toplevel",
            "description": "Top-level LaTeX entrypoint. Thin orchestration wrapper: loads metadata, style, and bibliography resource, then inputs all content sections."
        },
        {
            "path": "config/title.tex",
            "usage": "include",
            "description": "Canonical title source. Single source of truth for the paper title with intentional lowercase formatting. Defines \\papertitlemain, \\papertitlesubtitle, and \\papertitlefull macros."
        },
        {
            "path": "macros/metadata.tex",
            "usage": "include",
            "description": "Paper-level metadata commands (title, author, ORCID, version status). Loaded before the publication style. Inputs config/title.tex for the canonical title."
        },
        {
            "path": "styles/reflector.sty",
            "usage": "include",
            "description": "Publication style package. Swap this path to retarget a different publisher without modifying semantic content."
        },
        {
            "path": "references.bib",
            "usage": "include",
            "description": "BibLaTeX bibliography resource processed by biber."
        },
        {
            "path": "sections/abstract.tex",
            "usage": "include"
        },
        {
            "path": "sections/introduction.tex",
            "usage": "include"
        },
        {
            "path": "sections/recursive_drift.tex",
            "usage": "include"
        },
        {
            "path": "sections/reflective_auditing.tex",
            "usage": "include"
        },
        {
            "path": "sections/synchronization.tex",
            "usage": "include"
        },
        {
            "path": "sections/reflector_framework.tex",
            "usage": "include"
        },
        {
            "path": "sections/mixed_initiative_recursive_systems.tex",
            "usage": "include"
        },
        {
            "path": "sections/operational_demonstration.tex",
            "usage": "include"
        },
        {
            "path": "sections/implementation_examples.tex",
            "usage": "include"
        },
        {
            "path": "sections/case_studies.tex",
            "usage": "include"
        },
        {
            "path": "sections/limitations.tex",
            "usage": "include"
        },
        {
            "path": "sections/related_work.tex",
            "usage": "include"
        },
        {
            "path": "sections/future_directions.tex",
            "usage": "include"
        },
        {
            "path": "sections/conclusion.tex",
            "usage": "include"
        },
        {
            "path": "sections/appendix.tex",
            "usage": "include"
        },
        {
            "path": "figures/hero.png",
            "usage": "include",
            "description": "Hero figure: reflector system architecture overview."
        },
        {
            "path": "figures/figure1.png",
            "usage": "include"
        },
        {
            "path": "figures/figure2.png",
            "usage": "include"
        },
        {
            "path": "figures/figure3.png",
            "usage": "include"
        },
        {
            "path": "figures/figure4.png",
            "usage": "include"
        },
        {
            "path": "figures/figure5.png",
            "usage": "include"
        },
        {
            "path": "figures/figure6.png",
            "usage": "include"
        },
        {
            "path": "figures/figure7.png",
            "usage": "include"
        },
        {
            "path": "figures/figure8.png",
            "usage": "include"
        },
        {
            "path": "figures/figure9.png",
            "usage": "include"
        },
        {
            "path": "figures/figure10.png",
            "usage": "include"
        }
    ],

    "build": {
        "output_dir": ".cache/out",
        "aux_dir": ".cache/aux",
        "texinputs": [
            "./config//",
            "./styles//",
            "./macros//",
            "./sections//",
            "./figures//",
            "./diagrams//"
        ],
        "orchestration": ".latexmkrc",
        "script": "scripts/build-paper.sh"
    },

    "architecture": {
        "philosophy": "semantic content → publication manifest → renderer target → generated artifact",
        "renderer_target": "arxiv",
        "renderer_abstraction": "Swap paper/styles/reflector.sty to retarget a different publisher without modifying semantic source.",
        "future_portability": true
    }
}
