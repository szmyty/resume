use strict;
use warnings;

use File::Path qw(make_path);

###############################################################################
# cache directories
###############################################################################

$out_dir = ".cache/out";

$aux_dir = ".cache/aux";

$emulate_aux = 1;

make_path($out_dir);

make_path($aux_dir);

###############################################################################
# environment
###############################################################################

$ENV{"TEXINPUTS"} =
    "./sections//:"
    . "./styles//:"
    . "./assets//:";

$ENV{"TEXMFOUTPUT"} = $aux_dir;

###############################################################################
# build mode
###############################################################################

$pdf_mode = 1;

###############################################################################
# build behavior
###############################################################################

$silent = 1;

$max_repeat = 5;

$preview_mode = 0;

$do_cd = 1;

$force_mode = 1;
